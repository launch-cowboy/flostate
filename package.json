{
    "name": "flo-state",
    "productName": "Flo State",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "description": "Florence AI Agent Marketplace — Clinical Trial Operations Platform",
    "author": "Florence Healthcare",
    "main": "electron/main.cjs",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "preview": "vite preview",
        "record:walkthrough": "node scripts/record-walkthrough.mjs",
        "electron:dev": "npm run build && electron .",
        "electron:build": "npm run build && electron-builder --mac --win",
        "electron:build:mac": "npm run build && electron-builder --mac",
        "electron:build:win": "npm run build && electron-builder --win"
    },
    "dependencies": {
        "@radix-ui/react-icons": "^1.3.0",
        "@radix-ui/react-slot": "^1.0.2",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.1",
        "lucide-react": "^0.378.0",
        "pdfjs-dist": "^5.4.624",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^7.13.1",
        "recharts": "^2.12.7",
        "tailwind-merge": "^2.3.0",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@types/node": "^20.12.11",
        "@types/react": "^18.2.66",
        "@types/react-dom": "^18.2.22",
        "@typescript-eslint/eslint-plugin": "^7.2.0",
        "@typescript-eslint/parser": "^7.2.0",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.24",
        "electron": "^33.3.1",
        "electron-builder": "^25.1.8",
        "eslint": "^8.57.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.6",
        "postcss": "^8.5.6",
        "tailwindcss": "^3.4.19",
        "typescript": "^5.2.2",
        "vite": "^5.2.0"
    },
    "build": {
        "appId": "com.florencehealthcare.flostate",
        "productName": "Flo State",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "electron/**/*"
        ],
        "mac": {
            "category": "public.app-category.healthcare-fitness",
            "target": [
                {
                    "target": "dmg",
                    "arch": ["universal"]
                }
            ],
            "artifactName": "Flo-State-${version}-mac.${ext}"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": ["x64"]
                }
            ],
            "artifactName": "Flo-State-${version}-win.${ext}"
        },
        "nsis": {
            "oneClick": true,
            "allowToChangeInstallationDirectory": false,
            "artifactName": "Flo-State-${version}-Setup.${ext}"
        },
        "dmg": {
            "title": "Flo State",
            "artifactName": "Flo-State-${version}-mac.${ext}"
        }
    }
}
